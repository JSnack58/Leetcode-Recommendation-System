# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# --- Data Paths ---
# Root directory for all data files (raw, processed, features)
LRS_DATA_DIR=./data

# Root directory for serialized model artifacts
LRS_MODELS_DIR=./models

# --- LeetCode API ---
# Session cookie for authenticated API requests. The public contest ranking
# endpoint does NOT require this — leave blank unless you're scraping
# authenticated endpoints (e.g., a user's private profile).
LEETCODE_SESSION=

# Base URL for LeetCode. Override to point at a mock for local testing.
LEETCODE_BASE_URL=https://leetcode.com

# User-Agent string identifying this scraper.
SCRAPE_USER_AGENT=LRS-Research/0.1 (SJSU CMPE 256 term project)

# Rate limit: requests per second against the ranking endpoint.
# 0.25 = 1 request every 4 seconds (conservative; see ADR-0002).
SCRAPE_RATE_LIMIT_RPS=0.25

# Retry behavior for transient HTTP failures (429, 5xx, network blips).
SCRAPE_RETRY_MAX=5
SCRAPE_BACKOFF_BASE_SEC=2.0
SCRAPE_TIMEOUT_SEC=30.0

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Training ---
# Random seed for reproducibility
RANDOM_SEED=42
