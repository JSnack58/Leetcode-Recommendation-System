# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# --- Data Paths ---
# Root directory for all data files (raw, processed, features)
LRS_DATA_DIR=./data

# Root directory for serialized model artifacts
LRS_MODELS_DIR=./models

# --- LeetCode API ---
# Session cookie for authenticated API requests (scraping)
LEETCODE_SESSION=

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Training ---
# Random seed for reproducibility
RANDOM_SEED=42

# --- Web UI ---
FLASK_PORT=5001
